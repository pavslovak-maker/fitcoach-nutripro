# ============================================================
# FitCoach & NutriPro — Environment Variables
# Zkopíruj do .env a vyplň hodnoty
# ============================================================

# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://fitcoach:fitcoach_dev@localhost:5432/fitcoach_dev?schema=public

# ─── Redis (BullMQ queue + rate limiting) ─────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────
# Generuj: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_base64_64

# ─── Anthropic AI ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api-CHANGE_ME

# ─── Wearable OAuth (volitelné) ──────────────────────────
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
GARMIN_CALLBACK_URL=http://localhost:3001/auth/garmin/callback

WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_CALLBACK_URL=http://localhost:3001/auth/withings/callback

# ─── Encryption (GDPR — zdravotní data) ──────────────────
# Generuj: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key

# ─── Push Notifications (volitelné) ──────────────────────
FCM_SERVER_KEY=

# ─── Sentry (monitoring) ─────────────────────────────────
SENTRY_DSN=
