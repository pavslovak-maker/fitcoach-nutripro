      "static/chunks/main-app.js",
      "static/chunks/app/(app)/checkin/page.js"
    ],
    "/(app)/nutrition/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/nutrition/page.js"
    ],
    "/(app)/workout/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/workout/page.js"
    ],
    "/(app)/progress/page": [
      "static/chunks/webpack.js",
